server:
  port: 8000
  servlet:
    context-path: /api

spring:
  application:
    name: smart-home-system

  datasource:
    url: ${DB_URL}
    username: ${DB_USERNAME}
    password: ${DB_PASSWORD}
    driver-class-name: org.postgresql.Driver

  jpa:
      hibernate:
        ddl-auto: validate
      show-sql: false
      properties:
        hibernate:
          format_sql: false

jwt:
  secret: ${JWT_SECRET}
  expiration: 3600000
  issuer: group26.com

mqtt:
  broker: ${MQTT_BROKER_URL}
  client: spring-backend-client
  username: ${MQTT_USERNAME}
  key: ${MQTT_KEY}
  topics: ${mqtt.username}/feeds/+

logging:
  level:
    root: WARN

  file:
    path: logs
    name: smart-home-system.log

  logback:
    rollingpolicy:
      file-name-pattern: logs/smart-home-system-%d{yyyy-MM-dd}.%i.log.gz
      max-file-size: 1MB
      max-history: 7
